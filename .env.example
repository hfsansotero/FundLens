# Database
# Local dev: DuckDB (no server needed)
DATABASE_URL=duckdb:///./data/fundlens.duckdb

# Cloud deploy: Neon PostgreSQL (Phase 1 end / when hosting)
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/fundlens

# API Keys
TIINGO_API_KEY=your_tiingo_key_here   # Free at tiingo.com — backup source

# Pipeline schedule (24h format, market close + buffer)
DAILY_UPDATE_HOUR=18
DAILY_UPDATE_MINUTE=0

# Logging
LOG_LEVEL=INFO
